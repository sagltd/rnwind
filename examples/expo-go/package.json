{
  "name": "expo-go",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "code-check": "bun run lint && bun run typecheck",
    "inspect": "rm -rf .bundle-inspect && EXPO_NO_DOTENV=1 expo export --platform ios --dev --clear --output-dir .bundle-inspect && echo '\\nBundle at .bundle-inspect/_expo/static/js/ios/*.js'",
    "build:ios": "rm -rf .prod-bundle .rnwind && EXPO_NO_DOTENV=1 expo export --platform ios --clear --output-dir .prod-bundle && echo '\\nProduction bundle at .prod-bundle/_expo/static/js/ios/*.js'",
    "dump": "bun run scripts/dump-transform.ts",
    "dump:index": "bun run scripts/dump-transform.ts app/index.tsx",
    "dump:layout": "bun run scripts/dump-transform.ts app/_layout.tsx"
  },
  "dependencies": {
    "expo": "^56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-router": "~56.2.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "rnwind": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "tailwindcss": "^4.2.3",
    "typescript": "~6.0.3"
  }
}
