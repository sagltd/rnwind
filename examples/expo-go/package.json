{
  "name": "expo-go",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "code-check": "bun run lint && bun run typecheck",
    "inspect": "rm -rf .bundle-inspect && EXPO_NO_DOTENV=1 expo export --platform ios --dev --clear --output-dir .bundle-inspect && echo '\\nBundle at .bundle-inspect/_expo/static/js/ios/*.js'",
    "build:ios": "rm -rf .prod-bundle .rnwind && EXPO_NO_DOTENV=1 expo export --platform ios --clear --output-dir .prod-bundle && echo '\\nProduction bundle at .prod-bundle/_expo/static/js/ios/*.js'",
    "dump": "bun run scripts/dump-transform.ts",
    "dump:index": "bun run scripts/dump-transform.ts app/index.tsx",
    "dump:layout": "bun run scripts/dump-transform.ts app/_layout.tsx"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~14.0.2",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "rnwind": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.9.2"
  }
}
