{
  "name": "rnwind-monorepo",
  "version": "0.0.0",
  "author": "https://github.com/sagltd",
  "repository": "https://github.com/sagltd/rnwind",
  "devDependencies": {
    "@eslint-react/eslint-plugin": "2.8.1",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@happy-dom/global-registrator": "20.4.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@stylistic/eslint-plugin-jsx": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@types/bun": "^1.3.8",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "@types/use-sync-external-store": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "bun-types": "1.3.8",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-depend": "^1.4.0",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-sonarjs": "3.0.6",
    "eslint-plugin-unicorn": "62.0.0",
    "jest": "^30.2.0",
    "prettier": "3.8.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rnwind": "workspace:*",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "use-sync-external-store": "^1.6.0"
  },
  "description": "Tailwind for React Native",
  "homepage": "https://github.com/sagltd/rnwind",
  "keywords": [
    "react",
    "react-native",
    "tailwind",
    "tailwindcss",
    "styling",
    "rnwind"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "clean": "sudo rm -rf node_modules && sudo rm -rf packages/*/node_modules && bun install",
    "build": "bun --filter='./packages/*' run build",
    "test": "bun --filter='./packages/*' run test",
    "typecheck": "bun --filter='./packages/*' run typecheck",
    "lint": "bun --filter='./packages/*' run lint",
    "format": "bun --filter='./packages/*' run format",
    "code-check": "bun --filter='rnwind' --filter='@rnwind/e2e' run code-check",
    "pub": "bun run code-check && bun run build && cd packages/rnwind/lib && npm publish"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "examples/benchmark/apps/*",
    "examples/benchmark/packages/*"
  ],
  "dependencies": {
    "tailwindcss": "^4.0.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react-native": "0.81.5",
    "@testing-library/react-native": "13.3.3"
  }
}
