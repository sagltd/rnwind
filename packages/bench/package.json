{
  "name": "@rnwind/bench",
  "version": "0.0.0",
  "private": true,
  "description": "Fair perf + feature comparison between rnwind, NativeWind, and react-native-unistyles",
  "scripts": {
    "bench": "rm -rf reports/results.json .cache && jest --runInBand --no-cache && bun ./src/report.ts",
    "bench:run": "jest --runInBand --no-cache",
    "bench:report": "bun ./src/report.ts",
    "test": "jest --runInBand --no-cache",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint \"src/**/*.{ts,tsx}\" \"__tests__/**/*.{ts,tsx}\" \"fixtures/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"./**/*.{js,jsx,json,ts,tsx}\"",
    "code-check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "rnwind": "workspace:*"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.3",
    "react-native-worklets": "^0.6.1",
    "@testing-library/react-native": "^13.3.3",
    "tinybench": "^6.0.0",
    "uniwind": "^1.6.2"
  }
}
