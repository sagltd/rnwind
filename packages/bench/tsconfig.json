{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./lib",
    "jsx": "react-jsx",
    "types": ["node", "jest"],
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "moduleResolution": "bundler",
    "baseUrl": "../..",
    "paths": {
      "rnwind": ["packages/rnwind/src/index.ts"],
      "rnwind/metro": ["packages/rnwind/src/metro/index.ts"],
      "rnwind/metro/transformer": ["packages/rnwind/src/metro/transformer.ts"]
    }
  },
  "include": ["src/**/*", "__tests__/**/*", "fixtures/**/*"]
}
